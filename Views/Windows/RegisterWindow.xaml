<Window x:Class="UP_Markov.Views.Windows.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="550" Width="450"
        WindowStartupLocation="CenterScreen" Background="#121212">

    <Border Background="#252526" CornerRadius="15" Margin="30" Padding="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Регистрация" FontSize="26" FontWeight="Bold" Foreground="White" 
                       HorizontalAlignment="Center" Margin="0 0 0 20"/>

            <TextBlock Text="Логин" Foreground="#AAAAAA" Margin="0 5 0 2"/>
            <TextBox x:Name="LoginBox" Height="35" VerticalContentAlignment="Center" Padding="5 0"/>

            <TextBlock Text="Email" Foreground="#AAAAAA" Margin="0 10 0 2"/>
            <TextBox x:Name="EmailBox" Height="35" VerticalContentAlignment="Center" Padding="5 0"/>

            <TextBlock Text="Имя пользователя" Foreground="#AAAAAA" Margin="0 10 0 2"/>
            <TextBox x:Name="DisplayNameBox" Height="35" VerticalContentAlignment="Center" Padding="5 0"/>

            <TextBlock Text="Пароль" Foreground="#AAAAAA" Margin="0 10 0 2"/>
            <PasswordBox x:Name="PassBox" Height="35" VerticalContentAlignment="Center" Padding="5 0"/>

            <Button Content="Создать аккаунт" Height="40" Margin="0 30 0 10" 
                    Background="#3E3E42" Foreground="White" Click="Register_Click"/>

            <Button Content="Назад" Height="40" Background="Transparent" 
                    Foreground="#007ACC" BorderThickness="0" Click="Back_Click"/>
        </StackPanel>
    </Border>
</Window>