<Window x:Class="UP_Markov.Views.Windows.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация"
        Height="550"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid>

        <Border Width="350"
                Height="450"
                Background="#2D2D30"
                CornerRadius="15"
                Padding="20">

            <StackPanel>

                <TextBlock Text="Регистрация"
                           FontSize="28"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 20"/>

                <TextBox x:Name="LoginBox"
                         Height="35"
                         Margin="0 0 0 10"/>

                <TextBox x:Name="EmailBox"
                         Height="35"
                         Margin="0 0 0 10"/>

                <TextBox x:Name="DisplayNameBox"
                         Height="35"
                         Margin="0 0 0 10"/>

                <PasswordBox x:Name="PasswordBox"
                             Height="35"
                             Margin="0 0 0 20"/>

                <Button Content="Создать аккаунт"
                        Height="40"
                        Margin="0 0 0 10"
                        Click="RegisterButton_Click"/>

                <Button Content="Назад"
                        Height="40"
                        Click="BackButton_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>