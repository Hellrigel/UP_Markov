<UserControl x:Class="UP_Markov.Views.Components.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#252526">

    <StackPanel>

        <Button Content="📚"
                Height="70"
                FontSize="26"
                Click="Catalog_Click"
                ToolTip="Каталог"/>

        <Button Content="📖"
                Height="70"
                FontSize="26"
                Click="Lists_Click"
                ToolTip="Списки"/>

        <Button x:Name="AuthorButton"
                Content="✍"
                Height="70"
                FontSize="26"
                Click="Author_Click"
                ToolTip="Автор"/>

        <Button x:Name="AdminButton"
                Content="⚙"
                Height="70"
                FontSize="26"
                Click="Admin_Click"
                ToolTip="Админ"/>

        <Button Content="👤"
                Height="70"
                FontSize="26"
                Click="Profile_Click"
                ToolTip="Профиль"/>

    </StackPanel>

</UserControl>