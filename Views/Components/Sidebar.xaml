<UserControl x:Class="UP_Markov.Views.Components.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#252526">

    <Grid>

        <StackPanel>

            <Button Height="60"
                    Margin="10"
                    ToolTip="Каталог"
                    Click="CatalogButton_Click">

                <TextBlock Text="📚"
                           FontSize="24"/>
            </Button>

            <Button Height="60"
                    Margin="10"
                    ToolTip="Профиль"
                    Click="ProfileButton_Click">

                <TextBlock Text="👤"
                           FontSize="24"/>
            </Button>
            <Button Height="60"
        Margin="10"
        ToolTip="Списки"
        Click="ListsButton_Click">

                <TextBlock Text="📚"
               FontSize="24"/>

            </Button>
            <Button Height="60"
        Margin="10"
        ToolTip="Автор"
        Click="AuthorButton_Click">

                <TextBlock Text="✍"
               FontSize="24"/>

            </Button>

        </StackPanel>

    </Grid>

</UserControl>