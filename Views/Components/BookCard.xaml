<UserControl x:Class="UP_Markov.Views.Components.BookCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="320"
             Width="220">

    <Border BorderBrush="#444"
            BorderThickness="1"
            CornerRadius="15"
            Margin="10"
            Background="#2D2D30">

        <Grid>

            <StackPanel>

                <Border Height="180"
                        Background="#3E3E42"
                        CornerRadius="15 15 0 0">

                    <Image x:Name="CoverImage"
                           Stretch="UniformToFill"/>
                </Border>

                <StackPanel Margin="10">

                    <TextBlock x:Name="TitleText"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               TextWrapping="Wrap"/>

                    <TextBlock x:Name="AuthorText"
                               Foreground="#BBBBBB"
                               Margin="0 5 0 0"/>

                    <TextBlock x:Name="RatingText"
                               Foreground="Gold"
                               Margin="0 5 0 0"/>

                    <Button Content="Открыть"
                            Height="35"
                            Margin="0 10 0 0"
                            Click="OpenButton_Click"/>

                </StackPanel>

            </StackPanel>

        </Grid>

    </Border>

</UserControl>