<Page x:Class="UP_Markov.Views.Pages.EditBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E1E">

    <ScrollViewer>

        <StackPanel Margin="20"
                    Width="500">

            <TextBlock Text="Книга"
                       FontSize="32"
                       Foreground="White"
                       Margin="0 0 0 20"/>

            <TextBlock Text="Название"
                       Foreground="White"/>

            <TextBox x:Name="TitleBox"
                     Height="35"
                     Margin="0 5 0 15"/>

            <TextBlock Text="Описание"
                       Foreground="White"/>

            <TextBox x:Name="DescriptionBox"
                     Height="120"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Margin="0 5 0 15"/>

            <TextBlock Text="Текст книги"
                       Foreground="White"/>

            <TextBox x:Name="ContentBox"
                     Height="300"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Margin="0 5 0 20"/>

            <Button Content="Сохранить"
                    Height="40"
                    Click="SaveButton_Click"/>

        </StackPanel>

    </ScrollViewer>

</Page>