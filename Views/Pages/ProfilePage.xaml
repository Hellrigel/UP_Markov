<Page x:Class="UP_Markov.Views.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E1E">

    <Grid>

        <StackPanel Margin="20">

            <TextBlock Text="Профиль"
                       FontSize="32"
                       Foreground="White"
                       Margin="0 0 0 20"/>

            <TextBlock x:Name="LoginText"
                       FontSize="20"
                       Foreground="White"/>

            <TextBlock x:Name="EmailText"
                       FontSize="20"
                       Foreground="White"/>

            <TextBlock x:Name="RoleText"
                       FontSize="20"
                       Foreground="White"/>
            <TextBlock x:Name="FreezeText"
           FontSize="18"
           Foreground="Red"
           Margin="0 20 0 20"/>

            <Button x:Name="AuthorRequestButton"
        Content="Подать заявку на автора"
        Height="35"
        Margin="0 0 0 10"
        Click="AuthorRequestButton_Click"/>

            <Button x:Name="UnfreezeRequestButton"
        Content="Подать заявку на разморозку"
        Height="35"
        Click="UnfreezeRequestButton_Click"/>

        </StackPanel>

    </Grid>

</Page>