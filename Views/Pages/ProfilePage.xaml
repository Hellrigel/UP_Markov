<Page x:Class="UP_Markov.Views.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E1E">

    <Grid>

        <StackPanel Margin="20">

            <TextBlock Text="Профиль"
                       FontSize="32"
                       Foreground="White"
                       Margin="0 0 0 20"/>

            <TextBlock x:Name="LoginText"
                       FontSize="20"
                       Foreground="White"/>

            <TextBlock x:Name="EmailText"
                       FontSize="20"
                       Foreground="White"/>

            <TextBlock x:Name="RoleText"
                       FontSize="20"
                       Foreground="White"/>

        </StackPanel>

    </Grid>

</Page>