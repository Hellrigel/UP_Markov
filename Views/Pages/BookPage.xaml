<Page x:Class="UP_Markov.Views.Pages.BookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E1E">

    <ScrollViewer>

        <StackPanel Margin="20">

          

            <TextBlock x:Name="TitleText"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="White"/>
            

           

            <TextBlock x:Name="AuthorText"
                       FontSize="18"
                       Foreground="#BBBBBB"
                       Margin="0 10 0 20"/>

           

            <TextBlock x:Name="DescriptionText"
                       FontSize="16"
                       Foreground="White"
                       TextWrapping="Wrap"
                       Margin="0 0 0 20"/>

            

            <TextBlock Text="Рейтинг"
                       FontSize="22"
                       Foreground="White"
                       Margin="0 20 0 10"/>

            <TextBlock x:Name="RatingText"
                       FontSize="18"
                       Foreground="Gold"
                       Margin="0 0 0 20"/>

            

            <Button Content="Читать"
                    Height="40"
                    Width="200"
                    Margin="0 0 0 20"
                    Click="ReadButton_Click"/>

            

            <TextBlock Text="Добавить в список"
                       FontSize="22"
                       Foreground="White"
                       Margin="0 0 0 10"/>

            <ComboBox x:Name="StatusBox"
                      Width="200"
                      Height="35"
                      Margin="0 0 0 10"/>

            <Button Content="Сохранить список"
                    Width="200"
                    Height="35"
                    Margin="0 0 0 20"
                    Click="AddToList_Click"/>

            

            <Button Content="Пожаловаться на книгу"
                    Width="220"
                    Height="35"
                    Margin="0 0 0 30"
                    Click="ComplaintBook_Click"/>

            

            <TextBlock Text="Добавить отзыв"
                       FontSize="22"
                       Foreground="White"
                       Margin="0 0 0 10"/>

            <TextBox x:Name="ReviewBox"
                     Height="100"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Margin="0 0 0 10"/>

            <StackPanel Orientation="Horizontal"
                        Margin="0 0 0 10">

                <TextBlock Text="Оценка:"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <ComboBox x:Name="ReviewRatingBox"
                          Width="80"
                          Margin="10 0 0 0"/>

            </StackPanel>

            <Button Content="Отправить отзыв"
                    Width="200"
                    Height="35"
                    Margin="0 0 0 30"
                    Click="AddReview_Click"/>

            

            <TextBlock Text="Отзывы"
                       FontSize="26"
                       Foreground="White"
                       Margin="0 0 0 20"/>

            <StackPanel x:Name="ReviewsPanel"/>
            <ComboBox x:Name="RatingBox"
          Height="35"
          Width="100"/>

        </StackPanel>

    </ScrollViewer>

</Page>