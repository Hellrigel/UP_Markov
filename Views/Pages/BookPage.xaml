<Page x:Class="UP_Markov.Views.Pages.BookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E1E">

    <ScrollViewer>

        <StackPanel Margin="20">

            <TextBlock x:Name="TitleText"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="White"/>

            <TextBlock x:Name="AuthorText"
                       FontSize="18"
                       Foreground="#BBBBBB"
                       Margin="0 10 0 20"/>

            <TextBlock x:Name="DescriptionText"
                       FontSize="16"
                       Foreground="White"
                       TextWrapping="Wrap"
                       Margin="0 0 0 20"/>

            <Button Content="Читать"
                    Height="40"
                    Width="200"
                    Click="ReadButton_Click"/>

        </StackPanel>

    </ScrollViewer>

</Page>