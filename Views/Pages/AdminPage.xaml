<Page x:Class="UP_Markov.Views.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E1E">

    <ScrollViewer>

        <StackPanel Margin="30">

            <TextBlock Text="Администрирование"
                       FontSize="32"
                       Foreground="White"
                       Margin="0 0 0 30"/>

            <TextBlock Text="Жалобы"
                       FontSize="24"
                       Foreground="White"/>

            <StackPanel x:Name="ComplaintsPanel"
                        Margin="0 15 0 30"/>

            <TextBlock Text="Пользователи"
                       FontSize="24"
                       Foreground="White"/>

            <StackPanel x:Name="UsersPanel"
                        Margin="0 15 0 30"/>

        </StackPanel>

    </ScrollViewer>

</Page>