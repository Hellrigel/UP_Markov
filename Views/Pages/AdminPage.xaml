<Page x:Class="UP_Markov.Views.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E1E">

    <ScrollViewer>

        <StackPanel Margin="20">

            <TextBlock Text="Администрирование"
                       FontSize="32"
                       Foreground="White"
                       Margin="0 0 0 30"/>

           

            <TextBlock Text="Жалобы"
                       FontSize="24"
                       Foreground="White"
                       Margin="0 0 0 15"/>

            <StackPanel x:Name="ComplaintsPanel"
                        Margin="0 0 0 40"/>
           

            <TextBlock Text="Заявки на автора"
           FontSize="24"
           Foreground="White"
           Margin="0 0 0 15"/>

            <StackPanel x:Name="AuthorRequestsPanel"
            Margin="0 0 0 40"/>

            

            <TextBlock Text="Заявки на разморозку"
           FontSize="24"
           Foreground="White"
           Margin="0 0 0 15"/>

            <StackPanel x:Name="UnfreezeRequestsPanel"
            Margin="0 0 0 40"/>

            

            <TextBlock Text="Пользователи"
                       FontSize="24"
                       Foreground="White"
                       Margin="0 0 0 15"/>

            <StackPanel x:Name="UsersPanel"/>
            <TextBlock Text="Замороженные книги"
           FontSize="24"
           Foreground="White"
           Margin="0 30 0 15"/>

            <StackPanel x:Name="FrozenBooksPanel"/>

        </StackPanel>

    </ScrollViewer>

</Page>