<Page x:Class="UP_Markov.Views.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E1E">

    <Grid Margin="20">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

      

        <StackPanel Orientation="Horizontal"
                    Margin="0 0 0 20">

            <TextBox x:Name="SearchBox"
                     Width="250"
                     Height="35"
                     Margin="0 0 10 0"
                     TextChanged="SearchBox_TextChanged"/>

            <ComboBox x:Name="SortBox"
                      Width="180"
                      Height="35"
                      Margin="0 0 10 0"
                      SelectionChanged="SortBox_SelectionChanged">

                <ComboBoxItem Content="По названию"/>

                <ComboBoxItem Content="По рейтингу"/>

            </ComboBox>

            <ComboBox x:Name="GenreBox"
                      Width="180"
                      Height="35"
                      SelectionChanged="GenreBox_SelectionChanged"/>

        </StackPanel>

        

        <ScrollViewer Grid.Row="1">

            <WrapPanel x:Name="BooksPanel"/>

        </ScrollViewer>

    </Grid>

</Page>