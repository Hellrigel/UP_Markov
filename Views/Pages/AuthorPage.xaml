<Page x:Class="UP_Markov.Views.Pages.AuthorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E1E">

    <Grid Margin="20">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        

        <StackPanel Orientation="Horizontal"
                    Margin="0 0 0 20">

            <TextBlock Text="Мои книги"
                       FontSize="32"
                       Foreground="White"
                       VerticalAlignment="Center"/>

            <Button Content="Добавить книгу"
                    Width="180"
                    Height="40"
                    Margin="20 0 0 0"
                    Click="AddBook_Click"/>

        </StackPanel>

        

        <ScrollViewer Grid.Row="1">

            <StackPanel x:Name="BooksPanel"/>

        </ScrollViewer>

    </Grid>

</Page>