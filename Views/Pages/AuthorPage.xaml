<Page x:Class="UP_Markov.Views.Pages.AuthorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E1E">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="20">

            <!-- HEADER -->

            <TextBlock Text="Добавление новой книги"
                       FontSize="32"
                       Foreground="White"
                       Margin="0 0 0 25"/>

            <!-- TITLE -->

            <TextBlock Text="Название книги"
                       Foreground="White"
                       FontSize="16"
                       Margin="0 0 0 5"/>

            <TextBox x:Name="TitleBox"
                     Height="40"
                     Margin="0 0 0 15"/>

            <!-- DESCRIPTION -->

            <TextBlock Text="Описание книги"
                       Foreground="White"
                       FontSize="16"
                       Margin="0 0 0 5"/>

            <TextBox x:Name="DescriptionBox"
                     Height="100"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0 0 0 15"/>

            <!-- COVER -->

            <TextBlock Text="Путь к обложке"
                       Foreground="White"
                       FontSize="16"
                       Margin="0 0 0 5"/>

            <TextBox x:Name="CoverBox"
                     Height="40"
                     Margin="0 0 0 15"/>

            <!-- CONTENT -->

            <TextBlock Text="Текст книги"
                       Foreground="White"
                       FontSize="16"
                       Margin="0 0 0 5"/>

            <TextBox x:Name="ContentBox"
                     Height="220"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0 0 0 20"/>

            <!-- BUTTON -->

            <Button Content="Добавить книгу"
                    Width="220"
                    Height="45"
                    HorizontalAlignment="Left"
                    Click="AddBook_Click"/>

            <!-- MY BOOKS -->

            <TextBlock Text="Мои книги"
                       FontSize="30"
                       Foreground="White"
                       Margin="0 40 0 15"/>

            <StackPanel x:Name="BooksPanel">

                <TextBlock Text="У вас пока нет книг"
                           Foreground="Gray"
                           FontSize="18"/>

            </StackPanel>

            <!-- FROZEN BOOKS -->

            <TextBlock Text="Замороженные книги"
                       FontSize="30"
                       Foreground="#FF6666"
                       Margin="0 40 0 15"/>

            <StackPanel x:Name="FrozenBooksPanel"/>

        </StackPanel>

    </ScrollViewer>

</Page>