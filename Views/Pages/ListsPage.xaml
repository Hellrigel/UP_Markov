<Page x:Class="UP_Markov.Views.Pages.ListsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:components="clr-namespace:UP_Markov.Views.Components"
      Background="#1E1E1E">

    <Grid Margin="20">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        

        <StackPanel Orientation="Horizontal"
                    Margin="0 0 0 20">

            <ComboBox x:Name="StatusBox"
                      Width="180"
                      Height="35"
                      SelectionChanged="StatusBox_SelectionChanged">

                <ComboBoxItem Content="В планах"/>
                <ComboBoxItem Content="Читаю"/>
                <ComboBoxItem Content="Прочитано"/>
                <ComboBoxItem Content="Заброшено"/>

            </ComboBox>

            <TextBox x:Name="SearchBox"
                     Width="250"
                     Height="35"
                     Margin="10 0 0 0"
                     TextChanged="SearchBox_TextChanged"/>

        </StackPanel>

     

        <ScrollViewer Grid.Row="1">

            <WrapPanel x:Name="BooksPanel"/>

        </ScrollViewer>

    </Grid>

</Page>